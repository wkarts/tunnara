{
  "name": "tunnara-console",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev-web.mjs",
    "build": "npm run build:web",
    "preview": "vite preview",
    "tauri": "node ./scripts/ci/run-tauri.mjs",
    "tauri:dev": "npm run tauri -- dev",
    "tauri:build": "npm run tauri -- build",
    "tauri:build:debug": "npm run tauri -- build --debug",
    "tauri:bundle:mac": "npm run tauri -- bundle --bundles app,dmg",
    "build:web": "vue-tsc --noEmit && vite build",
    "build:web:tauri": "npm run build:web && node ./scripts/prepare-tauri-resources.mjs",
    "typecheck": "vue-tsc --noEmit",
    "ci:version": "node ./scripts/ci/check-version-sync.mjs",
    "ci:pr-title": "node ./scripts/ci/validate-pr-title.mjs",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --all-targets --all-features",
    "release:ci": "node ./scripts/release/run-semantic-release.mjs",
    "release:dry": "semantic-release --dry-run",
    "tauri:server": "cargo run --manifest-path src-tauri/Cargo.toml -- --mode=headless-api",
    "tauri:cli": "cargo run --manifest-path src-tauri/Cargo.toml -- --mode=cli",
    "tauri:worker": "cargo run --manifest-path src-tauri/Cargo.toml -- --mode=worker",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "fmt:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
    "ci:rust:features": "cargo build --manifest-path src-tauri/Cargo.toml --features mysql-db && cargo build --manifest-path src-tauri/Cargo.toml --features postgres-db && cargo build --manifest-path src-tauri/Cargo.toml --features mysql-db,postgres-db",
    "validate:rust": "npm run fmt:rust && npm run fmt:rust:check && npm run lint:rust && npm run test:rust && npm run ci:rust:features",
    "validate:web": "npm run ci:version && npm run typecheck && npm run build:web",
    "validate:all": "npm run validate:web && npm run validate:rust",
    "build:pwa": "npm run build:web",
    "dev:web": "node ./scripts/dev-web.mjs",
    "dev:web:lan": "node ./scripts/dev-web.mjs --lan",
    "dev:tauri": "vite --host 127.0.0.1 --port 1420",
    "new:app": "node ./scripts/create-derived-app.mjs",
    "env:model": "node ./scripts/print-env-model.mjs",
    "build:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/build-windows.ps1",
    "build:windows:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/build-windows.ps1 -Mode Debug",
    "build:windows:web": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/build-windows.ps1 -WebOnly",
    "build:windows:fast": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/build-windows.ps1 -SkipRustChecks",
    "npm:normalize-lock": "node ./scripts/npm/normalize-package-lock-registry.mjs",
    "build:windows:noinstall": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/build-windows.ps1 -NoInstall",
    "build:windows:offline": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/build-windows.ps1 -InstallMode Offline",
    "build:windows:install": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/build-windows.ps1 -InstallMode Install",
    "build:linux:cloudpanel": "bash ./scripts/linux/build-cloudpanel-release.sh --all",
    "build:linux:cloudpanel:x64": "bash ./scripts/linux/build-cloudpanel-release.sh --x64",
    "build:linux:cloudpanel:x86": "bash ./scripts/linux/build-cloudpanel-release.sh --x86",
    "build:linux:cloudpanel:docker": "bash ./scripts/linux/build-cloudpanel-release-docker.sh --all",
    "deps:linux:cloudpanel": "bash ./scripts/linux/install-cloudpanel-build-deps.sh --all",
    "deps:linux:cloudpanel:x64": "bash ./scripts/linux/install-cloudpanel-build-deps.sh --x64",
    "deps:linux:cloudpanel:x86": "bash ./scripts/linux/install-cloudpanel-build-deps.sh --x86"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "pinia": "^2.1.7",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.3",
    "vite": "^8.1.3",
    "vue-tsc": "^2.2.12"
  },
  "license": "Apache-2.0"
}
