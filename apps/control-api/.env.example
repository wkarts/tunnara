APP_NAME="Tunnara Control API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:7500
APP_VERSION=2.0.0-rc.1
LOG_CHANNEL=stderr
LOG_LEVEL=info

# sqlite | pgsql | mysql
DB_CONNECTION=sqlite
DB_DATABASE=/var/lib/tunnara-control/database.sqlite
# DB_HOST=postgres
# DB_PORT=5432
# DB_DATABASE=tunnara
# DB_USERNAME=tunnara
# DB_PASSWORD=change-me

# array | file | database | redis
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Redis opcional para cache, sessões, filas, presença e locks.
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

TUNNARA_CORS_ORIGINS=http://localhost:7400
TUNNARA_SERVICE_TOKEN=

# Comunicação interna entre Coordinator, Edge, Relay e Control API.
TUNNARA_CLUSTER_TOKEN=tnr_cluster_change_me
TUNNARA_PUBLIC_CONTROL_URL=http://localhost:7500
TUNNARA_PUBLIC_RELAY_URL=tcp://localhost:7300
