APP_NAME="Tunnara Control API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_VERSION=1.0.1

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Banco: sqlite | pgsql | mysql
DB_CONNECTION=sqlite
DB_DATABASE=/app/storage/database.sqlite
DB_FOREIGN_KEYS=true
DB_BUSY_TIMEOUT=5000
DB_JOURNAL_MODE=WAL
DB_SYNCHRONOUS=NORMAL

# PostgreSQL/MySQL quando usados
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=tunnara
DB_PASSWORD=change-me
DB_SSLMODE=prefer
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Estado de aplicação:
# memory = array/array/sync
# local  = file/file/sync
# database = database/database/database
# redis  = redis/redis/redis
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3
REDIS_CACHE_CONNECTION=cache
REDIS_QUEUE_CONNECTION=queue
SESSION_CONNECTION=session

RUN_MIGRATIONS=true
