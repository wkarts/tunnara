[Unit]
Description=Tunnara QUIC Bridge Client
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=tunnara
Group=tunnara
EnvironmentFile=-/etc/tunnara/quic-client.env
ExecStart=/usr/local/bin/tunnara-quic-bridge client
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true

[Install]
WantedBy=multi-user.target
