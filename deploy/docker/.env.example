# Tunnara Platform 2.0.0-rc.7
COMPOSE_PROJECT_NAME=tunnara
TUNNARA_VERSION=2.0.0-rc.7
TUNNARA_PULL_POLICY=missing
TUNNARA_DEPLOY_MODE=image

TUNNARA_SERVER_IMAGE=ghcr.io/wkarts/tunnara-server:2.0.0-rc.7
TUNNARA_AGENT_IMAGE=ghcr.io/wkarts/tunnara-agent:2.0.0-rc.7
TUNNARA_CONSOLE_IMAGE=ghcr.io/wkarts/tunnara-console:2.0.0-rc.7
TUNNARA_CONTROL_IMAGE=ghcr.io/wkarts/tunnara-control-api:2.0.0-rc.7
TUNNARA_CADDY_IMAGE=ghcr.io/wkarts/tunnara-caddy-cloudflare:2.0.0-rc.7
TUNNARA_QUIC_IMAGE=ghcr.io/wkarts/tunnara-quic-bridge:2.0.0-rc.7

TUNNARA_BOOTSTRAP_ADMIN_TOKEN=tnr_admin_change_me
TUNNARA_MASTER_KEY_BASE64=change_me
TUNNARA_CLUSTER_TOKEN=tnr_cluster_change_me
TUNNARA_BOOTSTRAP_ORGANIZATION=Tunnara Community
TUNNARA_STORAGE_DRIVER=sqlite

CONTROL_BIND=127.0.0.1
CONTROL_PORT=7100
EDGE_BIND=0.0.0.0
EDGE_PORT=8080
RELAY_BIND=0.0.0.0
RELAY_PORT=7300
CONSOLE_BIND=0.0.0.0
CONSOLE_PORT=7400
PUBLIC_BIND=0.0.0.0
PUBLIC_PORT_MIN=20000
PUBLIC_PORT_MAX=20100

TUNNARA_BASE_DOMAIN=tunnara.local
TUNNARA_PUBLIC_SCHEME=http
TUNNARA_PUBLIC_CONTROL_URL=http://127.0.0.1:7100
TUNNARA_PUBLIC_RELAY_URL=tcp://127.0.0.1:7300
TUNNARA_CORS_ORIGIN=http://localhost:7400
TUNNARA_LOG_FORMAT=json
TUNNARA_REPLAY_EDGE_BASE_URL=http://tunnara-server:7200
TUNNARA_HEALTH_SCHEDULER_INTERVAL_MS=5000
TUNNARA_HEALTH_CHECK_CONCURRENCY=16
TUNNARA_INSPECTOR_RETENTION_DAYS=7
TUNNARA_INSPECTOR_MAX_RECORDS=10000

# Observabilidade opcional
PROMETHEUS_BIND=127.0.0.1
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
GRAFANA_BIND=127.0.0.1
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me

# Produção Cloudflare/ACME
CLOUDFLARE_ZONE_NAME=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
TUNNARA_ACME_EMAIL=
TUNNARA_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
TUNNARA_CLOUDFLARE_EDGE_ADDRESS=
TUNNARA_QUIC_PUBLIC_HOST=
TUNNARA_QUIC_PORT=7443

# Plano distribuído Laravel/PostgreSQL/Redis
APP_KEY=
DB_DATABASE=tunnara
DB_USERNAME=tunnara
DB_PASSWORD=change_me
REDIS_PASSWORD=change_me
