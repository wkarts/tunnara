# Tunnara Platform 1.1.1 — ambiente Docker modular
COMPOSE_PROJECT_NAME=tunnara
TUNNARA_VERSION=1.1.3
TUNNARA_DEPLOY_MODE=image
TUNNARA_PULL_POLICY=missing

# Imagens oficiais. Altere somente ao usar registry ou fork próprio.
TUNNARA_SERVER_IMAGE=ghcr.io/wkarts/tunnara-server:1.1.3
TUNNARA_AGENT_IMAGE=ghcr.io/wkarts/tunnara-agent:1.1.3
TUNNARA_CONSOLE_IMAGE=ghcr.io/wkarts/tunnara-console:1.1.3
TUNNARA_CONTROL_IMAGE=ghcr.io/wkarts/tunnara-control-api:1.1.3
TUNNARA_CADDY_IMAGE=ghcr.io/wkarts/tunnara-caddy-cloudflare:1.1.3
TUNNARA_QUIC_IMAGE=ghcr.io/wkarts/tunnara-quic-bridge:1.1.3

# O comando ./tunnara.sh init substitui automaticamente estes placeholders.
TUNNARA_BOOTSTRAP_ADMIN_TOKEN=tnr_admin_change_me
TUNNARA_MASTER_KEY_BASE64=change-me
TUNNARA_CLUSTER_TOKEN=tnr_cluster_change_me
TUNNARA_BOOTSTRAP_ORGANIZATION=Tunnara Community

# Persistência padrão para instalação local/VPS single-node.
TUNNARA_STORAGE_DRIVER=sqlite

# Publicação local dos serviços.
CONTROL_BIND=127.0.0.1
CONTROL_PORT=7100
EDGE_BIND=0.0.0.0
EDGE_PORT=8080
RELAY_BIND=0.0.0.0
RELAY_PORT=7300
CONSOLE_BIND=0.0.0.0
CONSOLE_PORT=7400
PUBLIC_BIND=0.0.0.0
PUBLIC_PORT_MIN=20000
PUBLIC_PORT_MAX=20100

# Endereços públicos padrão para desenvolvimento local.
TUNNARA_BASE_DOMAIN=tunnara.local
TUNNARA_PUBLIC_SCHEME=http
TUNNARA_PUBLIC_CONTROL_URL=http://127.0.0.1:7100
TUNNARA_PUBLIC_RELAY_URL=tcp://127.0.0.1:7300
TUNNARA_CORS_ORIGIN=http://localhost:7400
TUNNARA_LOG_FORMAT=json

# Produção com Cloudflare/Let's Encrypt/QUIC. Substitua antes de usar.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ZONE_NAME=example.com
CLOUDFLARE_API_TOKEN=change-me
CLOUDFLARED_TUNNEL_TOKEN=
TUNNARA_ACME_EMAIL=admin@example.com
TUNNARA_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
TUNNARA_CLOUDFLARE_EDGE_ADDRESS=203.0.113.10
TUNNARA_QUIC_PUBLIC_HOST=relay.example.com
TUNNARA_QUIC_PORT=7443
TUNNARA_QUIC_CERT_WAIT_SECONDS=300
TUNNARA_QUIC_LOG=info
TUNNARA_PUBLIC_HOST=
TUNNARA_AUTO_DNS=true

# Providers externos opcionais usados pela composição de storage.
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me
REDIS_PASSWORD=change-me
