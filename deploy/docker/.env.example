COMPOSE_PROJECT_NAME=tunnara
TUNNARA_SERVER_IMAGE=ghcr.io/wwsoftwares/tunnara-server:1.0.1
TUNNARA_CONSOLE_IMAGE=ghcr.io/wwsoftwares/tunnara-console:1.0.1
TUNNARA_CADDY_IMAGE=tunnara-caddy-cloudflare:1.0.1

# Gerados por ./tunnara.sh init
TUNNARA_BOOTSTRAP_ADMIN_TOKEN=change-me
TUNNARA_MASTER_KEY_BASE64=change-me
TUNNARA_CLUSTER_TOKEN=change-me
TUNNARA_BOOTSTRAP_ORGANIZATION=Tunnara Community

# Runtime embarcado: sqlite persistente ou memory efêmero
TUNNARA_STORAGE_DRIVER=sqlite

# Domínio público
TUNNARA_BASE_DOMAIN=tunnel.example.com
TUNNARA_PUBLIC_HOST=edge.example.com
TUNNARA_PUBLIC_CONTROL_URL=https://control.tunnel.example.com
TUNNARA_PUBLIC_RELAY_URL=quic://relay.tunnel.example.com:7443
TUNNARA_PUBLIC_SCHEME=https
TUNNARA_CORS_ORIGIN=https://console.tunnel.example.com
TUNNARA_LOG_FORMAT=json
TUNNARA_AUTO_DNS=true

# Cloudflare + ACME DNS-01
CLOUDFLARE_ZONE_NAME=example.com
CLOUDFLARE_API_TOKEN=change-me
TUNNARA_ACME_EMAIL=admin@example.com
TUNNARA_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
TUNNARA_CLOUDFLARE_EDGE_ADDRESS=203.0.113.10
TUNNARA_CLOUDFLARE_EDGE_HOSTNAME=
CLOUDFLARED_TUNNEL_TOKEN=

CONTROL_PORT=7100
EDGE_BIND=0.0.0.0
EDGE_PORT=8080
RELAY_PORT=7300
CONSOLE_PORT=7400
PUBLIC_PORT_MIN=20000
PUBLIC_PORT_MAX=20100

# QUIC Agent ↔ Relay
TUNNARA_QUIC_IMAGE=ghcr.io/wwsoftwares/tunnara-quic-bridge:1.0.1
TUNNARA_QUIC_PUBLIC_HOST=relay.tunnel.example.com
TUNNARA_QUIC_PORT=7443
TUNNARA_QUIC_CERT_WAIT_SECONDS=300
TUNNARA_QUIC_LOG=info
