# Tunnara Platform 1.1.0
COMPOSE_PROJECT_NAME=tunnara
TUNNARA_VERSION=1.1.0
TUNNARA_REGISTRY=ghcr.io/wkarts
TUNNARA_DEPLOY_MODE=image
TUNNARA_PULL_POLICY=missing

# Imagens opcionais. Deixe vazio para usar TUNNARA_REGISTRY/TUNNARA_VERSION.
TUNNARA_SERVER_IMAGE=ghcr.io/wkarts/tunnara-server:1.1.0
TUNNARA_AGENT_IMAGE=ghcr.io/wkarts/tunnara-agent:1.1.0
TUNNARA_CONSOLE_IMAGE=ghcr.io/wkarts/tunnara-console:1.1.0
TUNNARA_CONTROL_IMAGE=ghcr.io/wkarts/tunnara-control-api:1.1.0
TUNNARA_CADDY_IMAGE=ghcr.io/wkarts/tunnara-caddy-cloudflare:1.1.0
TUNNARA_QUIC_IMAGE=ghcr.io/wkarts/tunnara-quic-bridge:1.1.0

# Gerados automaticamente por ./tunnara.sh init
TUNNARA_BOOTSTRAP_ADMIN_TOKEN=change-me
TUNNARA_MASTER_KEY_BASE64=change-me
TUNNARA_CLUSTER_TOKEN=change-me
TUNNARA_BOOTSTRAP_ORGANIZATION=Tunnara Community

# Runtime embarcado funcional: sqlite persistente ou memory efêmero.
TUNNARA_STORAGE_DRIVER=sqlite

# Bind e portas locais.
CONTROL_BIND=127.0.0.1
CONTROL_PORT=7100
EDGE_BIND=0.0.0.0
EDGE_PORT=8080
RELAY_BIND=0.0.0.0
RELAY_PORT=7300
CONSOLE_BIND=0.0.0.0
CONSOLE_PORT=7400
PUBLIC_BIND=0.0.0.0
PUBLIC_PORT_MIN=20000
PUBLIC_PORT_MAX=20100

# Desenvolvimento/local.
TUNNARA_BASE_DOMAIN=tunnara.local
TUNNARA_PUBLIC_SCHEME=http
TUNNARA_PUBLIC_CONTROL_URL=http://127.0.0.1:7100
TUNNARA_PUBLIC_RELAY_URL=tcp://127.0.0.1:7300
TUNNARA_CORS_ORIGIN=http://localhost:7400
TUNNARA_LOG_FORMAT=json
TUNNARA_AUTO_DNS=false

# Produção pública.
TUNNARA_PUBLIC_HOST=edge.example.com
CLOUDFLARE_ZONE_NAME=example.com
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=change-me
TUNNARA_ACME_EMAIL=admin@example.com
TUNNARA_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
TUNNARA_CLOUDFLARE_EDGE_ADDRESS=203.0.113.10
TUNNARA_CLOUDFLARE_EDGE_HOSTNAME=
CLOUDFLARED_TUNNEL_TOKEN=

# QUIC Agent ↔ Relay.
TUNNARA_QUIC_PUBLIC_HOST=relay.example.com
TUNNARA_QUIC_PORT=7443
TUNNARA_QUIC_CERT_WAIT_SECONDS=300
TUNNARA_QUIC_LOG=info
