COMPOSE_PROJECT_NAME=tunnara-control
TUNNARA_CONTROL_IMAGE=ghcr.io/wkarts/tunnara-control-api:2.0.0-rc.6
TUNNARA_CONSOLE_IMAGE=ghcr.io/wkarts/tunnara-console:2.0.0-rc.6

APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
LOG_LEVEL=info

CONTROL_API_PORT=8080
CONSOLE_PORT=7400

DB_DATABASE=tunnara
DB_USERNAME=tunnara
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me
REDIS_PASSWORD=change-me

# Valores derivados pelo storage.sh:
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
