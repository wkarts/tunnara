COMPOSE_PROJECT_NAME=tunnara-control
TUNNARA_CONTROL_IMAGE=ghcr.io/wwsoftwares/tunnara-control-api:1.0.1
TUNNARA_CONSOLE_IMAGE=ghcr.io/wwsoftwares/tunnara-console:1.0.1

APP_ENV=production
APP_KEY=change-me
APP_DEBUG=false
APP_URL=http://localhost:8080
LOG_LEVEL=info

CONTROL_API_PORT=8080
CONSOLE_PORT=7400

DB_DATABASE=tunnara
DB_USERNAME=tunnara
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me
REDIS_PASSWORD=change-me

# Valores derivados pelo storage.sh:
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
