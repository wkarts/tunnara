APP_ENV=production
APP_KEY=base64:GENERATE_32_BYTES
APP_URL=https://control.tunnel.example.com
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tunnara
DB_USERNAME=tunnara
DB_PASSWORD=change-me
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
CACHE_STORE=redis
