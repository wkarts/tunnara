QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_CACHE_CONNECTION=cache
REDIS_QUEUE_CONNECTION=queue
SESSION_CONNECTION=session
RUN_MIGRATIONS=true
