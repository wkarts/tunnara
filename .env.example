# Tunnara Platform 2.0.0-rc.8 — runtime embedded local
TUNNARA_STORAGE_DRIVER=sqlite
TUNNARA_DATA_DIR=./data

TUNNARA_CONTROL_HOST=127.0.0.1
TUNNARA_CONTROL_PORT=7100
TUNNARA_EDGE_HOST=0.0.0.0
TUNNARA_EDGE_PORT=7200
TUNNARA_RELAY_HOST=0.0.0.0
TUNNARA_RELAY_PORT=7300
TUNNARA_RELAY_EDGE_HOST=127.0.0.1
TUNNARA_RELAY_EDGE_PORT=7301

TUNNARA_BASE_DOMAIN=tunnara.local
TUNNARA_PUBLIC_SCHEME=http
TUNNARA_PUBLIC_CONTROL_URL=http://127.0.0.1:7100
TUNNARA_PUBLIC_RELAY_URL=tcp://127.0.0.1:7300
TUNNARA_CORS_ORIGIN=http://localhost:7400

TUNNARA_BOOTSTRAP_ORGANIZATION=Tunnara Community
# Gere com:
# node -e "console.log('tnr_admin_'+require('node:crypto').randomBytes(32).toString('base64url'))"
TUNNARA_BOOTSTRAP_ADMIN_TOKEN=
# Gere 32 bytes Base64:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
TUNNARA_MASTER_KEY_BASE64=
TUNNARA_CLUSTER_TOKEN=

TUNNARA_LOG_FORMAT=json
TUNNARA_REPLAY_EDGE_BASE_URL=http://127.0.0.1:7200
TUNNARA_HEALTH_SCHEDULER_INTERVAL_MS=5000
TUNNARA_HEALTH_CHECK_CONCURRENCY=16
TUNNARA_INSPECTOR_RETENTION_DAYS=7
TUNNARA_INSPECTOR_MAX_RECORDS=10000
